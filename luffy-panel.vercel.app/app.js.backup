async function disableSMSForwarding() {
  try {
    const response = await fetch('/api/forward/sms', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ action: 'disable' })
    });

    const result = await response.json();
    
    if (result.success) {
      alert('SMS forwarding disabled');
      document.getElementById('smsForwardPhone').value = '';
    } else {
      alert(`Failed to disable SMS forwarding: ${result.error || 'Unknown error'}`);
    }
  } catch (error) {
    console.error('SMS forwarding error:', error);
    alert('Failed to disable SMS forwarding. Please try again.');
  }
}

// Bot functions
function updateFormatPreview() {
  const format = document.getElementById('messageFormat').value;
  const preview = document.getElementById('formatPreview');
  
  const formats = {
    auto: {
      title: '🔍 Auto-detect (try all formats)',
      desc: 'Tries all formats automatically. Any of the examples below will work.'
    },
    selected: {
      title: '📋 Selected format preview',
      desc: 'Tries all formats automatically. Any of the examples below will work.'
    },
    'sms-tg': {
      title: '💬 SMS → Telegram (auto-forward)',
      desc: 'Every new SMS on the device is automatically forwarded to your configured chat every 4s.'
    }
  };

  const info = formats[format] || formats.auto;
  preview.innerHTML = `
    <h5>${info.title}</h5>
    <p>${info.desc}</p>
  `;
}

function addBotLog(message) {
  const logBox = document.getElementById('botLog');
  const entry = document.createElement('div');
  entry.className = 'log-entry';
  entry.textContent = `[${new Date().toLocaleTimeString()}] ${message}`;
  logBox.appendChild(entry);
  logBox.scrollTop = logBox.scrollHeight;
}

function clearBotLog() {
  document.getElementById('botLog').innerHTML = '';
}

function updateBotStatus(online) {
  const dot = document.getElementById('botStatusDot');
  const text = document.getElementById('botStatusText');
  
  if (online) {
    dot.classList.add('online');
    text.textContent = 'Bot Online - 0 sent';
  } else {
    dot.classList.remove('online');
    text.textContent = 'Bot Offline';
  }
}

async function startBot() {
  const token = document.getElementById('botToken').value;
  const chatId = document.getElementById('chatId').value;
  const format = document.getElementById('messageFormat').value;
  const autoForward = document.getElementById('autoForwardPhone').value;
  const template = document.getElementById('smsTemplate').value;

  if (!token || !chatId) {
    alert('Please enter both bot token and chat ID');
    return;
  }

  botConfig = { token, chatId, format, autoForward, template };

  try {
    const response = await fetch('/api/bot/start', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        ...botConfig,
        sim: botSim,
        repeat: botRepeat
      })
    });

    const result = await response.json();
    
    if (result.success) {
      botRunning = true;
      updateBotStatus(true);
      addBotLog('Bot started successfully');
      addBotLog(`Monitoring chat: ${chatId}`);
      addBotLog(`Using SIM ${botSim} for sending`);
    } else {
      alert(`Failed to start bot: ${result.error || 'Unknown error'}`);
      addBotLog(`Error: ${result.error || 'Failed to start'}`);
    }
  } catch (error) {
    console.error('Start bot error:', error);
    alert('Failed to start bot. Please try again.');
    addBotLog(`Error: ${error.message}`);
  }
}

async function saveConfig() {
  const token = document.getElementById('botToken').value;
  const chatId = document.getElementById('chatId').value;
  const format = document.getElementById('messageFormat').value;
  const autoForward = document.getElementById('autoForwardPhone').value;
  const template = document.getElementById('smsTemplate').value;

  botConfig = { token, chatId, format, autoForward, template };

  try {
    localStorage.setItem('botConfig', JSON.stringify({
      ...botConfig,
      sim: botSim,
      repeat: botRepeat
    }));
    
    alert('Bot configuration saved successfully!');
    addBotLog('Configuration saved');
  } catch (error) {
    console.error('Save config error:', error);
    alert('Failed to save configuration. Please try again.');
  }
}

// Load saved config on page load
document.addEventListener('DOMContentLoaded', () => {
  try {
    const saved = localStorage.getItem('botConfig');
    if (saved) {
      const config = JSON.parse(saved);
      document.getElementById('botToken').value = config.token || '';
      document.getElementById('chatId').value = config.chatId || '';
      document.getElementById('messageFormat').value = config.format || 'auto';
      document.getElementById('autoForwardPhone').value = config.autoForward || '';
      document.getElementById('smsTemplate').value = config.template || '';
      
      if (config.sim) {
        botSim = config.sim;
        selectBotSim(config.sim);
      }
      
      if (config.repeat) {
        botRepeat = config.repeat;
        selectBotRepeat(config.repeat);
      }
      
      updateFormatPreview();
    }
  } catch (error) {
    console.error('Load config error:', error);
  }
});
