// Global state
let currentTab = 'info';
let selectedSim = 1;
let selectedRepeat = 1;
let botSim = 1;
let botRepeat = 1;
let botRunning = false;
let botConfig = {
  token: '',
  chatId: '',
  format: 'auto',
  autoForward: '',
  template: ''
};

// Tab switching
function switchTab(tabName) {
  // Remove active class from all tabs and contents
  document.querySelectorAll('.tab').forEach(tab => tab.classList.remove('active'));
  document.querySelectorAll('.tab-content').forEach(content => content.classList.remove('active'));
  
  // Add active class to selected tab and content
  document.querySelector(`button[onclick="switchTab('${tabName}')"]`).classList.add('active');
  document.getElementById(`${tabName}-tab`).classList.add('active');
  
  currentTab = tabName;
}

// SIM selection for Send tab
function selectSim(simNumber) {
  selectedSim = simNumber;
  document.querySelectorAll('#send-tab .sim-btn').forEach(btn => btn.classList.remove('active'));
  event.target.classList.add('active');
  document.getElementById('simDisplay').textContent = simNumber;
}

// Repeat selection for Send tab
function selectRepeat(count) {
  selectedRepeat = count;
  document.querySelectorAll('#send-tab .repeat-btn').forEach(btn => btn.classList.remove('active'));
  event.target.classList.add('active');
}

// SIM selection for Bot tab
function selectBotSim(simNumber) {
  botSim = simNumber;
  document.querySelectorAll('#bot-tab .sim-btn').forEach(btn => btn.classList.remove('active'));
  event.target.classList.add('active');
}

// Repeat selection for Bot tab
function selectBotRepeat(count) {
  botRepeat = count;
  document.querySelectorAll('#bot-tab .repeat-btn').forEach(btn => btn.classList.remove('active'));
  event.target.classList.add('active');
}

// Character counter for SMS
document.addEventListener('DOMContentLoaded', () => {
  const messageInput = document.getElementById('sendMessage');
  if (messageInput) {
    messageInput.addEventListener('input', () => {
      document.getElementById('charCount').textContent = `${messageInput.value.length} chars`;
    });
  }
});

// Send SMS function
async function sendSMS() {
  const phone = document.getElementById('sendPhone').value;
  const message = document.getElementById('sendMessage').value;

  if (!phone || !message) {
    alert('Please enter both phone number and message');
    return;
  }

  try {
    const response = await fetch('/api/sms/send', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        phone,
        message,
        sim: selectedSim,
        repeat: selectedRepeat
      })
    });

    const result = await response.json();
    
    if (result.success) {
      alert(`SMS sent successfully via SIM ${selectedSim}!`);
      document.getElementById('sendMessage').value = '';
    } else {
      alert(`Failed to send SMS: ${result.error || 'Unknown error'}`);
    }
  } catch (error) {
    console.error('Send SMS error:', error);
    alert('Failed to send SMS. Please try again.');
  }
}

// Call forwarding functions
async function setCallForwarding() {
  const phone = document.getElementById('callForwardPhone').value;
  
  if (!phone) {
    alert('Please enter a phone number');
    return;
  }

  try {
    const response = await fetch('/api/forward/call', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ phone, action: 'enable' })
    });

    const result = await response.json();
    
    if (result.success) {
      alert(`Call forwarding enabled to ${phone}`);
    } else {
      alert(`Failed to enable call forwarding: ${result.error || 'Unknown error'}`);
    }
  } catch (error) {
    console.error('Call forwarding error:', error);
    alert('Failed to set call forwarding. Please try again.');
  }
}

async function disableCallForwarding() {
  try {
    const response = await fetch('/api/forward/call', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ action: 'disable' })
    });

    const result = await response.json();
    
    if (result.success) {
      alert('Call forwarding disabled');
      document.getElementById('callForwardPhone').value = '';
    } else {
      alert(`Failed to disable call forwarding: ${result.error || 'Unknown error'}`);
    }
  } catch (error) {
    console.error('Call forwarding error:', error);
    alert('Failed to disable call forwarding. Please try again.');
  }
}

// SMS forwarding functions
