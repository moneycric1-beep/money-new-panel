    });

    const result = await response.json();
    
    if (result.success) {
      alert(`SMS forwarding enabled to ${phone}`);
    } else {
      alert(`Failed to enable SMS forwarding: ${result.error || 'Unknown error'}`);
    }
  } catch (error) {
    console.error('SMS forwarding error:', error);
    alert('Failed to set SMS forwarding. Please try again.');
  }
